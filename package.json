    "diff": "^7.0.0",
    "execa": "^9.6.0",
    "fast-glob": "^3.3.3",
    "ora": "^8.2.0",
    "prompts": "^2.4.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/diff": "^6.0.0",
    "@types/node": "^22.10.5",
    "@types/prompts": "^2.4.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
